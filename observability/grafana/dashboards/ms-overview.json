      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "up{job=~\"ms-reportes.*\"}",
          "legendFormat": "{{job}} {{environment}}"
        }
      ],
      "title": "Reportes - scrape UP",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (application, uri) (rate(http_server_requests_seconds_count{application=~\"$application\"}[1m]))",
          "legendFormat": "{{application}} {{uri}}"
        }
      ],
      "title": "HTTP requests / s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (application, le) (rate(http_server_requests_seconds_bucket{application=~\"$application\"}[5m])))",
          "legendFormat": "p95 {{application}}"
        }
      ],
      "title": "HTTP latency p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{application=~\"$application\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx {{application}}"
        }
      ],
      "title": "HTTP 5xx / s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (application) (jvm_memory_used_bytes{application=~\"$application\", area=\"heap\"})",
          "legendFormat": "{{application}}"
        }
      ],
      "title": "JVM heap used",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 7,
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=~\"$application\"}",
          "legendFormat": "{{application}} active"
        },
        {
          "expr": "hikaricp_connections_idle{application=~\"$application\"}",
          "legendFormat": "{{application}} idle"
        }
      ],
      "title": "HikariCP connections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(feign_Client_seconds_count{application=\"ms-reportes\"}[1m]))",
          "legendFormat": "Feign calls/s"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(feign_Client_seconds_bucket{application=\"ms-reportes\"}[5m])) by (le))",
          "legendFormat": "Feign p95 (s)"
        }
      ],
      "title": "Feign client (MS Reportes -> Finanzas)",
      "type": "timeseries"
    }
  ],
