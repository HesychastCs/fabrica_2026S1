# Copia a .env y edita prometheus/prometheus.yml con tus hostnames Render,
# o reemplaza REPLACE_FINANZAS_HOST / REPLACE_REPORTES_HOST en prometheus.yml.
#
# Ejemplo (solo hostname, sin https:// ni rutas):
# RENDER_FINANZAS_HOST=ms-finanzas-xxxx.onrender.com
# RENDER_REPORTES_HOST=ms-reportes-xxxx.onrender.com

RENDER_FINANZAS_HOST=REPLACE_FINANZAS_HOST.onrender.com
RENDER_REPORTES_HOST=REPLACE_REPORTES_HOST.onrender.com
